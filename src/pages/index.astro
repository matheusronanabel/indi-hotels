---
import BaseLayout from '../layouts/BaseLayout.astro';
import Icon from '../components/Icon.astro';
import SectionHead from '../components/SectionHead.astro';
import CtaBand from '../components/CtaBand.astro';
import PhotoBlock from '../components/PhotoBlock.astro';
import { CTA, SERVICES, JOURNEY, TIERS, SITE, PULL_QUOTES } from '../data/site.js';

const opportunities = [
  { icon: 'acquisition', title: 'Smarter acquisition', body: 'Keep more of every booking working for you.' },
  { icon: 'price_trend', title: 'Pricing that moves with the market', body: 'Capture demand as it happens, day to day.' },
  { icon: 'team_pull', title: 'One team, pulling together', body: 'Distribution, marketing and web working as one.' },
  { icon: 'clarity', title: 'Clarity on your upside', body: 'See exactly where the growth is, and go after it.' },
];
---

<BaseLayout
  title="Commercial services for independent hotels"
  description={SITE.description}
  path="/"
  schema="organization"
>
  <!-- HERO -->
  <section class="bg-sky/30 relative overflow-hidden">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0 pt-6 pb-10 md:pt-20 md:pb-16 relative grid gap-12 lg:grid-cols-[1.15fr_0.85fr] items-center">
      <div>
        <span class="eyebrow block mb-5" data-aos="fade-up">
          Commercial services for independent hotels
        </span>
        <h1 class="display text-[clamp(34px,6.5vw,64px)] max-w-[17ch]" style="hyphens:none" data-aos="fade-up">
          <span class="text-[var(--color-azure)]">Indi</span> is the commercial team behind high&#8209;performing independent hotels.
        </h1>
        <p class="subhead text-[clamp(16px,2.2vw,19px)] text-[var(--color-grey)] max-w-[40ch] mt-7" data-aos="fade-up" data-aos-delay="80">
          You stay focused on your guests. We run your distribution, revenue management and digital marketing, growing your revenue and your direct bookings.
        </p>
        <div class="flex flex-col sm:flex-row flex-w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto items-center gap-x-7 gap-y-4 mt-9" data-aos="fade-up" data-aos-delay="140">
          <a href={CTA.href} class="btn block w-fit btn-azure text-[15px]">{CTA.label}</a>
          <a href="/how-we-work" class="link text-[var(--color-ink)] hover:text-[var(--color-azure)]">
            See how we work
            <Icon name="arrow_forward" size={17} />
          </a>
        </div>
      </div>
      <div class="hidden lg:block" data-aos="fade-left" data-aos-delay="180">
        <PhotoBlock
          aspect="portrait"
          label="Independent hotels, performing better"
          alt="An independent hotel property"
        />
      </div>
    </div>
  </section>

  <!-- THE OPPORTUNITY -->
  <section class="py-20 md:py-28">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0">
      <SectionHead
        eyebrow="The opportunity"
        heading="Imagine your commercials in expert hands."
        note="You've built something independent, with its own character, run your way. What most owners never get is a full commercial team behind it, the people who live and breathe distribution, pricing and marketing every day. That's what Indi brings, specialists dedicated to your revenue, so the property performs at its best while you stay focused on your guests."
      />
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mt-12">
        {opportunities.map((o, i) => (
          <div class="card p-6" data-aos="fade-up" data-aos-delay={i * 70}>
            <Icon name={o.icon} size={26} class="text-[var(--color-grey)]" />
            <h3 class="font-semibold text-[17px] mt-4">{o.title}</h3>
            <p class="text-[14.5px] text-[var(--color-grey)] mt-1.5 leading-relaxed">{o.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT WE DO -->
  <section class="py-20 md:py-28 bg-[var(--color-mist-grey)]">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0">
      <SectionHead
        eyebrow="What we do"
        heading="One team for everything that drives your revenue."
        note="Indi brings your distribution, revenue management and marketing under one roof, coordinated, not stitched together. And when you need just one thing done, we take on standalone projects too."
      />
      <div class="grid gap-4 md:grid-cols-3 mt-12">
        {SERVICES.map((s, i) => (
          <a
            href={`/services/${s.slug}`}
            class="card p-7 group flex flex-col transition-all hover:-translate-y-1 hover:shadow-[0_22px_44px_-26px_rgba(0,0,0,0.32)]"
            data-aos="fade-up"
            data-aos-delay={i * 80}
          >
            <span
              class="w-11 h-11 rounded-[10px] flex items-center justify-center"
              style="background:var(--color-azure)"
            >
              <Icon name={s.icon} size={22} class="text-white" />
            </span>
            <h3 class="display text-[23px] mt-5">{s.label}</h3>
            <p class="text-[15px] text-[var(--color-grey)] mt-3 leading-relaxed flex-1">{s.tile}</p>
            <span class="tlink mt-6">
              Explore
              <Icon name="arrow_forward" size={16} class="transition-transform group-hover:translate-x-1" />
            </span>
          </a>
        ))}
      </div>
      <a
        href="/services/projects"
        class="card p-7 group flex flex-col sm:flex-row sm:items-center sm:justify-between gap-6 mt-4 border-dashed bg-transparent shadow-none hover:-translate-y-1 transition-all"
        data-aos="fade-up"
      >
        <div>
          <span class="eyebrow">Projects</span>
          <h3 class="display text-[21px] mt-2">A different way to buy: standalone projects.</h3>
          <p class="text-[15px] text-[var(--color-grey)] mt-2 leading-relaxed max-w-[52ch]">A new website, GDS activation, a PMS setup or dynamic pricing. One-off, fixed scope, delivered by the same expert team.</p>
        </div>
        <span class="tlink shrink-0">
          Explore
          <Icon name="arrow_forward" size={16} class="transition-transform group-hover:translate-x-1" />
        </span>
      </a>
    </div>
  </section>

  <!-- HOW IT WORKS (3 steps) -->
  <section class="py-20 md:py-28 bg-white">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0">
      <SectionHead
        eyebrow="How it works"
        heading="A clear path, from first look to ongoing partnership."
      />
      <div class="grid gap-x-8 gap-y-10 sm:grid-cols-3 mt-14">
        {JOURNEY.map((step, i) => (
          <div class="relative" data-aos="fade-up" data-aos-delay={i * 70}>
            <span class="font-semibold text-[13px] text-[var(--color-azure)]">{step.n}</span>
            <div class="h-px bg-[var(--color-line)] mt-3 mb-5"></div>
            <h3 class="font-semibold text-[18px]">{step.title}</h3>
            <p class="text-[15px] text-[var(--color-grey)] mt-2 leading-relaxed">{step.body}</p>
          </div>
        ))}
      </div>
      <div class="mt-12 flex flex-wrap gap-x-8 gap-y-3" data-aos="fade-up">
        <a href="/how-we-work" class="tlink">
          See how we work in detail
          <Icon name="arrow_forward" size={16} />
        </a>
      </div>
    </div>
  </section>

  <!-- TIERS -->
  <section class="py-20 md:py-28 bg-[var(--color-ink)] text-[var(--color-paper)]">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0">
      <SectionHead
        light
        eyebrow="Your level of support"
        heading="Choose your level of support."
        note="Every property is different, so support is too. The difference between tiers isn't how often we talk, it's how much of the day-to-day commercial work you'd like us to run."
      />
      <div class="grid gap-4 md:grid-cols-3 mt-12">
        {TIERS.map((t, i) => (
          <div
            class="rounded-2xl border border-[#34373a] bg-[#202225] p-7 flex flex-col relative"
            data-aos="fade-up"
            data-aos-delay={i * 80}
          >
            {t.popular && (
              <span class="badge absolute -top-3 left-1/2 -translate-x-1/2">
                Most popular
              </span>
            )}
            <span class="font-semibold text-[12px] text-[#9a9c9e]">{t.cadence}</span>
            <h3 class="display text-[26px] mt-2 text-[var(--color-paper)]">{t.line}</h3>
            <div class="h-px bg-[#34373a] my-5"></div>
            <p class="text-[14.5px] text-[#C9C9C6] leading-relaxed flex-1">{t.best}</p>
            {t.cadence === 'Quarterly' && (
              <p class="text-[13px] text-[#9a9c9e] mt-4 leading-relaxed border-t border-[#34373a] pt-4">
                Quarterly is strategic oversight rather than active day-to-day pricing. The more of the execution you hand to Indi, the more of the upside we can help you capture.
              </p>
            )}
          </div>
        ))}
      </div>
      <p class="text-[12px] text-[#9a9c9e] mt-6">
        All partnerships run on a minimum 12-month term.
      </p>
      <div class="mt-9" data-aos="fade-up">
        <a href={CTA.href} class="btn block w-fit btn-paper">{CTA.label}</a>
      </div>
    </div>
  </section>

  <!-- TESTIMONIAL -->
  <section class="py-20 md:py-28 bg-[var(--color-sand)]">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0">
      <SectionHead
        human
        eyebrow="In their words"
        heading="Owners, talking about Indi."
      />
      <div class="grid gap-4 md:grid-cols-3 mt-12">
        {PULL_QUOTES.map((t, i) => (
          <div class="card-human p-8 flex flex-col justify-center" data-aos="fade-up" data-aos-delay={i * 80}>
            <p class="serif-italic text-[clamp(17px,2vw,21px)] text-[var(--color-ink)] leading-snug">
              "{t.quote}"
            </p>
            <p class="font-semibold text-[12px] text-[var(--color-clay)] mt-6">
              {t.name} · {t.role} · {t.property}
            </p>
          </div>
        ))}
      </div>
      <a href="/our-work" class="tlink mt-8" data-aos="fade-up">
        Read what owners say
        <Icon name="arrow_forward" size={16} class="transition-transform group-hover:translate-x-1" />
      </a>
    </div>
  </section>

  <CtaBand
    heading="See your property through an expert's eyes."
    sub="A free commercial discovery across your distribution, revenue and marketing, with clear, practical ideas to help your hotel perform at its best. No cost, no commitment."
  />
</BaseLayout>
