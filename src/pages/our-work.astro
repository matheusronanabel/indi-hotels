---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHead from '../components/SectionHead.astro';
import CtaBand from '../components/CtaBand.astro';
import PhotoBlock from '../components/PhotoBlock.astro';
import CaseStudy from '../components/CaseStudy.astro';
import Icon from '../components/Icon.astro';
import { CTA, TESTIMONIALS, PROPERTIES } from '../data/site.js';
import { CASE_STUDIES } from '../data/caseStudies.js';
import 'swiper/css';
import 'swiper/css/navigation';
import 'swiper/css/pagination';
---

<BaseLayout
  title="Our Work: the owners and properties we work with"
  description="Real properties, real owners, real commercial outcomes. Hear from the hotels and motels that trust Indi with their commercials."
  path="/our-work"
>
  <!-- HERO -->
  <section class="bg-[var(--color-paper)]">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0 pt-28 pb-24 md:pt-36 md:pb-32 grid gap-12 lg:grid-cols-[1.1fr_0.9fr] items-center">
      <div>
        <span class="eyebrow block mb-4" data-aos="fade-up">Our Work</span>
        <h1 class="display text-[clamp(34px,6vw,62px)] max-w-[18ch]" data-aos="fade-up">
          The owners and properties we work with.
        </h1>
        <p class="subhead text-[clamp(19px,2.4vw,24px)] text-[var(--color-grey)] max-w-[44ch] mt-7" data-aos="fade-up" data-aos-delay="80">
          Independent owners across Australia trust Indi with their commercials. Here's who they are, and what they say.
        </p>
        <a href={CTA.href} class="btn block w-fit btn-azure mt-10" data-aos="fade-up" data-aos-delay="140">{CTA.label}</a>
      </div>
      <div class="hidden lg:block" data-aos="fade-left" data-aos-delay="180">
        <PhotoBlock
          aspect="wide"
          label="Real outcomes, honestly presented"
          alt="Hotel property performing well"
        />
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS (container) -->
  <section class="py-20 md:py-28 bg-[var(--color-sand)]">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0">
      <SectionHead human eyebrow="In their words" heading="What owners say." note="Shared directly by the owners we work with, published exactly as they wrote it." />
      <div class="testimonial-swiper mt-12" data-aos="fade-up">
        <div class="swiper">
          <div class="swiper-wrapper">
            {TESTIMONIALS.map((t) => (
              <div class="swiper-slide">
                <div class="card-human p-7 flex flex-col h-full">
                  <Icon name="format_quote" size={30} class="text-[var(--color-sand-line)]" fill={1} />
                  <p class="serif-italic text-[16px] text-[#3a3b3d] leading-relaxed mt-3 flex-1">{t.quote}</p>
                  <div class="mt-6 pt-5 border-t border-[var(--color-sand-line)]">
                    <p class="font-semibold text-[12px] text-[var(--color-clay)]">{t.name} · {t.role} · {t.property}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="flex items-center justify-center gap-5 mt-8">
          <button type="button" class="testimonial-nav testimonial-prev" aria-label="Previous testimonial">
            <Icon name="arrow_forward" size={18} class="rotate-180" />
          </button>
          <div class="testimonial-pagination"></div>
          <button type="button" class="testimonial-nav testimonial-next" aria-label="Next testimonial">
            <Icon name="arrow_forward" size={18} />
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- A CLOSER LOOK (case studies) -->
  <section class="py-20 md:py-28 bg-[var(--color-sand)]">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0">
      <SectionHead human eyebrow="A closer look" heading="Three properties, priced with intent." note="Built around the strategy and, where an owner has shared one, their own words. We publish RevPAR growth only, never room counts, occupancy, ADR or total revenue, so a property's numbers stay its own." />
      <div class="grid gap-6 mt-12">
        {CASE_STUDIES.map((cs) => (
          <div data-aos="fade-up">
            <CaseStudy {...cs} />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROPERTIES -->
  <section id="properties" class="py-20 md:py-28 bg-[var(--color-sand)]">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0">
      <SectionHead human eyebrow="Who we work with" heading="Hotels and motels that trust Indi with their commercials." note="Presented as the independent owners and properties Indi works with, never as an owned collection." />
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 mt-12">
        {PROPERTIES.map((p, i) => (
          p.url ? (
            <a href={p.url} target="_blank" rel="noopener" class="card overflow-hidden flex flex-col group" data-aos="fade-up" data-aos-delay={(i % 6) * 50}>
              <PhotoBlock src={p.image ?? undefined} aspect="landscape" label={p.name} alt={`${p.name}, ${p.location}`} />
              <div class="p-6 flex items-center justify-between">
                <div>
                  <h3 class="font-semibold text-[16px]">{p.name}</h3>
                  <p class="text-[13.5px] text-[var(--color-grey)] mt-1">{p.location}</p>
                </div>
                <Icon name="north_east" size={18} class="text-[var(--color-line)] group-hover:text-[var(--color-ink)] transition-colors shrink-0" />
              </div>
            </a>
          ) : (
            <div class="card overflow-hidden flex flex-col" data-aos="fade-up" data-aos-delay={(i % 6) * 50}>
              <PhotoBlock src={p.image ?? undefined} aspect="landscape" label={p.name} alt={`${p.name}, ${p.location}`} />
              <div class="p-6">
                <h3 class="font-semibold text-[16px]">{p.name}</h3>
                <p class="text-[13.5px] text-[var(--color-grey)] mt-1">{p.location}</p>
              </div>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <CtaBand heading="Your property could be next." sub="Start with a free discovery. We'll show you where the upside is." />
</BaseLayout>

<script>
  import Swiper from 'swiper';
  import { Navigation, Pagination, Autoplay } from 'swiper/modules';

  new Swiper('.testimonial-swiper .swiper', {
    modules: [Navigation, Pagination, Autoplay],
    slidesPerView: 'auto',
    spaceBetween: 20,
    loop: true,
    grabCursor: true,
    autoplay: {
      delay: 4500,
      disableOnInteraction: false,
      pauseOnMouseEnter: true,
    },
    navigation: {
      nextEl: '.testimonial-next',
      prevEl: '.testimonial-prev',
    },
    pagination: {
      el: '.testimonial-pagination',
      clickable: true,
    },
  });
</script>
