---
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE } from '../data/site.js';
---

<BaseLayout
  title="Contact Indi"
  description="Get in touch with Indi, the commercial team behind independent hotels and motels in Australia."
  path="/contact"
>
  <section class="bg-[var(--color-paper)]">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0 pt-28 pb-24 md:pt-36 md:pb-32">
      <span class="eyebrow block mb-4" data-aos="fade-up">Contact</span>
      <h1 class="display text-[clamp(32px,5.6vw,56px)] max-w-[18ch]" data-aos="fade-up">
        Get in touch.
      </h1>
      <p class="subhead text-[clamp(19px,2.4vw,24px)] text-[var(--color-grey)] max-w-[46ch] mt-7" data-aos="fade-up" data-aos-delay="80">
        Have a question, or something specific to ask? Send us a message and we'll get back to you.
      </p>
    </div>
  </section>

  <section class="py-16 md:py-24">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0 grid gap-12 lg:grid-cols-[0.85fr_1.15fr] items-start">
      <!-- Contact details -->
      <div data-aos="fade-up">
        <span class="eyebrow">Contact details</span>
        <div class="mt-6 space-y-4">
          <div>
            <p class="text-[12px] font-semibold text-[var(--color-grey)]">Email</p>
            <a href={`mailto:${SITE.email}`} class="text-[16px] text-[var(--color-ink)] font-semibold">{SITE.email}</a>
          </div>
          <div>
            <p class="text-[12px] font-semibold text-[var(--color-grey)]">Phone</p>
            <a href={`tel:${SITE.phone.replace(/\s+/g, '')}`} class="text-[16px] text-[var(--color-ink)] font-semibold">{SITE.phone}</a>
          </div>
          <div>
            <p class="text-[12px] font-semibold text-[var(--color-grey)]">Address</p>
            <p class="text-[16px] text-[var(--color-ink)] font-semibold">
              {SITE.address.street}, {SITE.address.suburb} {SITE.address.state} {SITE.address.postcode}, Australia
            </p>
            <p class="text-[16px] text-[var(--color-ink)] font-semibold mt-2">
              {SITE.addressBali}
            </p>
          </div>
        </div>
        <div class="mt-8 rounded-xl bg-[var(--color-ash)] p-6">
          <p class="text-[14.5px] text-[#4a4b4d] leading-relaxed">
            Looking for a free commercial discovery instead?
            <a href="/free-discovery" class="text-[var(--color-ink)] font-semibold underline decoration-[var(--color-line)] underline-offset-2">Start here</a>.
          </p>
        </div>
      </div>

      <!-- Form -->
      <div class="card p-7 md:p-9" data-aos="fade-up" data-aos-delay="80">
        <form id="contact-form" class="space-y-5">
          <!-- honeypot: hidden from real users, bots that autofill every field trip it -->
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="name" class="block text-[13px] font-semibold mb-1.5">Your name</label>
              <input id="name" name="name" type="text" required class="field" autocomplete="name" />
            </div>
            <div>
              <label for="property" class="block text-[13px] font-semibold mb-1.5">Property name</label>
              <input id="property" name="property" type="text" required class="field" />
            </div>
          </div>

          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="email" class="block text-[13px] font-semibold mb-1.5">Email</label>
              <input id="email" name="email" type="email" required class="field" autocomplete="email" />
            </div>
            <div>
              <label for="phone" class="block text-[13px] font-semibold mb-1.5">Phone <span class="text-[var(--color-grey)] font-normal">(optional)</span></label>
              <input id="phone" name="phone" type="tel" class="field" autocomplete="tel" />
            </div>
          </div>

          <div>
            <label for="message" class="block text-[13px] font-semibold mb-1.5">Message</label>
            <textarea id="message" name="message" rows="5" required class="field resize-y" placeholder="What can we help with?"></textarea>
          </div>

          <button type="submit" id="submit-btn" class="btn block w-full btn-azure justify-center text-[15px]">
            Send message
          </button>
          <p id="form-status" class="text-[14px] text-center" role="status" aria-live="polite"></p>
          <p class="text-[12px] text-[var(--color-grey)] text-center leading-relaxed">
            We'll only use your details to reply to your message.
          </p>
        </form>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .field {
    width: 100%;
    font-family: var(--font-body);
    font-size: 15px;
    padding: 11px 14px;
    border: 1px solid var(--color-line);
    border-radius: 9px;
    background: var(--color-white);
    color: var(--color-ink);
    transition: border-color 0.16s ease, box-shadow 0.16s ease;
  }
  .field:focus {
    outline: none;
    border-color: var(--color-azure);
    box-shadow: 0 0 0 3px rgba(14, 79, 176, 0.14);
  }
  .field::placeholder { color: #9a9c9e; }
</style>

<script is:inline>
  // TODO(Abel): this form isn't wired to a submission target yet. Once you have
  // a Google Form (or other endpoint) for general contact, mirror the pattern in
  // free-discovery.astro: set GOOGLE_FORM_ACTION to its formResponse URL, and map
  // each field below to that form's entry.<id>. Until then, submissions are NOT
  // sent anywhere — the form tells the visitor to email/call directly instead, so
  // no one thinks they've reached us when they haven't.
  const GOOGLE_FORM_ACTION = ''; // e.g. 'https://docs.google.com/forms/d/e/XXXX/formResponse'
  const ENTRY_MAP = {
    name: '', // e.g. 'entry.123456789'
    property: '',
    email: '',
    phone: '',
    message: '',
  };
  const WIRED = Boolean(GOOGLE_FORM_ACTION) && Object.values(ENTRY_MAP).every(Boolean);

  const form = document.getElementById('contact-form');
  const status = document.getElementById('form-status');
  const btn = document.getElementById('submit-btn');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    status.style.color = 'var(--color-grey)';

    // Honeypot: real users never see or fill this field, so a checked box means a bot.
    if (form.querySelector('[name="botcheck"]').checked) {
      form.reset();
      status.style.color = 'var(--color-azure)';
      status.textContent = "Thanks, we've got your message and will be in touch shortly.";
      btn.textContent = 'Message sent';
      return;
    }

    if (!WIRED) {
      console.warn('[contact form] No submission target configured yet — see TODO in contact.astro.');
      const email = document.querySelector('a[href^="mailto:"]')?.textContent || '';
      const phone = document.querySelector('a[href^="tel:"]')?.textContent || '';
      status.style.color = 'var(--color-grey)';
      status.textContent = `This form isn't connected yet — please email ${email} or call ${phone} directly for now.`;
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Sending…';
    status.textContent = '';

    const formData = new FormData(form);
    const payload = new URLSearchParams();
    for (const [field, entry] of Object.entries(ENTRY_MAP)) {
      payload.set(entry, formData.get(field) || '');
    }

    try {
      // Google Forms doesn't send CORS headers, so the response is opaque here:
      // a no-cors POST always resolves, even on failure, so we show success optimistically.
      await fetch(GOOGLE_FORM_ACTION, {
        method: 'POST',
        mode: 'no-cors',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: payload,
      });
      form.reset();
      status.style.color = 'var(--color-azure)';
      status.textContent = "Thanks, we've got your message and will be in touch shortly.";
      btn.textContent = 'Message sent';
    } catch (err) {
      status.style.color = 'var(--color-azure)';
      status.textContent = 'Sorry, that didn’t send. Please email us directly and we’ll sort it.';
      btn.disabled = false;
      btn.textContent = 'Send message';
    }
  });
</script>
