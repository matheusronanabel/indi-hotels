---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHead from '../../components/SectionHead.astro';
import CtaBand from '../../components/CtaBand.astro';
import Icon from '../../components/Icon.astro';
import { CTA, PULL_QUOTES } from '../../data/site.js';
import { SERVICE_PAGES, SERVICE_ORDER } from '../../data/services.js';

export function getStaticPaths() {
  return SERVICE_ORDER.map((slug) => ({ params: { slug }, props: { slug } }));
}

const { slug } = Astro.props;
interface ServicePage {
  label: string;
  icon: string;
  accent: string;
  seoTitle: string;
  seoDesc: string;
  h1: string;
  sub: string;
  problemHeading: string;
  leadIn?: string;
  problemBody: string;
  connective?: string;
  work: string[][];
  delivery: string;
  crossLink?: { label: string; href: string };
  closing: string;
}
const pages = SERVICE_PAGES as Record<string, ServicePage>;
const p = pages[slug];

// next service for cross-link
const idx = SERVICE_ORDER.indexOf(slug);
const nextSlug = SERVICE_ORDER[(idx + 1) % SERVICE_ORDER.length];
const next = pages[nextSlug];

// rotate a different owner pull-quote per capability page
const pullQuote = PULL_QUOTES[idx % PULL_QUOTES.length];
---

<BaseLayout
  title={p.seoTitle}
  description={p.seoDesc}
  path={`/services/${slug}`}
  serviceName={p.label}
>
  <!-- HERO -->
  <section class="bg-[var(--color-paper)]">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0 pt-28 pb-24 md:pt-36 md:pb-32">
      <span class="inline-flex items-center gap-2.5 mb-6" data-aos="fade-up">
        <span class="w-9 h-9 rounded-lg flex items-center justify-center" style={`background:${p.accent}`}>
          <Icon name={p.icon} size={20} class="text-white" />
        </span>
        <span class="eyebrow">{p.label}</span>
      </span>
      <h1 class="display text-[clamp(32px,5.6vw,58px)] max-w-[20ch]" data-aos="fade-up">{p.h1}</h1>
      <p class="subhead text-[clamp(19px,2.4vw,24px)] text-[var(--color-grey)] max-w-[46ch] mt-7" data-aos="fade-up" data-aos-delay="80">
        {p.sub}
      </p>
      <a href={CTA.href} class="btn block w-fit btn-azure mt-10" data-aos="fade-up" data-aos-delay="140">{CTA.label}</a>
    </div>
  </section>

  <!-- PROBLEM -->
  <section class="py-20 md:py-28">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0-narrow">
      <SectionHead eyebrow="The problem" heading={p.problemHeading} />
      {p.leadIn && (
        <p class="text-[18px] leading-relaxed tracking-[-0.01em] text-[#3a3b3d] mt-6 max-w-[64ch]" data-aos="fade-up">
          {p.leadIn}
        </p>
      )}
      <p class="text-[18px] leading-relaxed tracking-[-0.01em] text-[#3a3b3d] mt-6 max-w-[64ch]" data-aos="fade-up">
        {p.problemBody}
      </p>
      {p.connective && (
        <p class="text-[18px] leading-relaxed tracking-[-0.01em] text-[#3a3b3d] mt-6 max-w-[64ch]" data-aos="fade-up">
          {p.connective}
        </p>
      )}
    </div>
  </section>

  <!-- WHAT INDI DOES -->
  <section class="py-20 md:py-28 bg-[var(--color-mist-grey)]">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0">
      <SectionHead eyebrow="What Indi does" heading="The actual work." />
      <div class="grid gap-4 md:grid-cols-2 mt-12">
        {p.work.map((row: string[], i: number) => {
          const [t, b] = row;
          return (
            <div class="card p-6 flex gap-4" data-aos="fade-up" data-aos-delay={(i % 2) * 70}>
              <span class="font-semibold text-[12px] text-[var(--color-grey)] pt-1 shrink-0">
                {String(i + 1).padStart(2, '0')}
              </span>
              <div>
                <h3 class="font-semibold text-[17px]">{t}</h3>
                <p class="text-[15px] text-[var(--color-grey)] mt-1.5 leading-relaxed">{b}</p>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- HOW IT'S DELIVERED -->
  <section class="py-20 md:py-28">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0-narrow">
      <SectionHead eyebrow="How it's delivered" heading="Built in onboarding. Run at the intensity you choose." />
      <p class="text-[18px] leading-relaxed tracking-[-0.01em] text-[#3a3b3d] mt-6 max-w-[64ch]" data-aos="fade-up">{p.delivery}</p>
      <div class="mt-8 flex flex-wrap gap-x-8 gap-y-3" data-aos="fade-up">
        <a href="/how-we-work" class="tlink">See how we work<Icon name="arrow_forward" size={16} /></a>
        <a href="/services/projects" class="tlink">See standalone projects<Icon name="arrow_forward" size={16} /></a>
        {p.crossLink && (
          <a href={p.crossLink.href} class="tlink">{p.crossLink.label}<Icon name="arrow_forward" size={16} /></a>
        )}
      </div>
    </div>
  </section>

  <!-- IN THEIR WORDS (one-line pull-quote, per §1.4) -->
  <section class="py-20 md:py-28 bg-[var(--color-sand)]">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0">
      <p class="serif-italic text-[clamp(20px,2.4vw,26px)] text-[var(--color-ink)] leading-snug max-w-[46ch]" data-aos="fade-up">
        "{pullQuote.quote}"
      </p>
      <p class="font-semibold text-[13px] text-[var(--color-clay)] mt-5" data-aos="fade-up">
        {pullQuote.name} · {pullQuote.role} · {pullQuote.property}
      </p>
      <div class="mt-6" data-aos="fade-up">
        <a href="/our-work" class="tlink">Read what owners say<Icon name="arrow_forward" size={16} /></a>
      </div>
    </div>
  </section>

  <!-- NEXT SERVICE -->
  <section class="py-16">
    <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0">
      <a href={`/services/${nextSlug}`} class="card p-7 flex items-center justify-between group hover:-translate-y-1 transition-all" data-aos="fade-up">
        <div>
          <span class="font-semibold text-[12px] text-[var(--color-grey)]">Next capability</span>
          <h3 class="display text-[24px] mt-1">{next.label}</h3>
        </div>
        <Icon name="arrow_forward" size={26} class="text-[var(--color-grey)] group-hover:translate-x-1 group-hover:text-[var(--color-ink)] transition-all" />
      </a>
    </div>
  </section>

  <CtaBand heading={p.closing} sub="A free discovery across your distribution, revenue and marketing. No cost, no commitment." />
</BaseLayout>
