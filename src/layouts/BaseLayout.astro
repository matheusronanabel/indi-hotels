---
import '../styles/global.css';
import Seo from '../components/Seo.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../data/site.js';

interface Props {
  title: string;
  description: string;
  path: string;
  schema?: 'organization' | 'service' | 'webpage';
  serviceName?: string;
}
const { title, description, path, schema, serviceName } = Astro.props;
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" sizes="180x180" href="/indi-logo-assets/indi-app-icon-180.png" />
    <link rel="sitemap" href="/sitemap.xml" />

    <!-- Fonts: Fraunces / Inter + Material Symbols -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..600;1,9..144,300..500&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <Seo title={title} description={description} path={path} schema={schema} serviceName={serviceName} />

    <!-- AOS -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.css" />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-3 focus:left-3 focus:z-[100] focus:bg-[var(--color-ink)] focus:text-[var(--color-paper)] focus:px-6 focus:py-2 focus:rounded-md">
      Skip to content
    </a>
    <Header />
    <main id="main" class="pt-[68px]">
      <slot />
    </main>
    <Footer />

    <script src="https://cdnjs.cloudflare.com/ajax/libs/aos/2.3.4/aos.js" is:inline></script>
    <script is:inline>
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (window.AOS) {
        window.AOS.init({
          duration: 650,
          easing: 'ease-out-cubic',
          once: true,
          offset: 60,
          disable: reduced,
        });
      }
    </script>
  </body>
</html>
