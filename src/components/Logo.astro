---
// Indi logo — Lockup 5b: Ascent mark (three ascending bars + beacon, reading as
// a lowercase "i") + "Indi" wordmark in Space Grotesk 700.
// Ink by default. Azure is for favicons, tiles and brand moments, not every lockup.
interface Props {
  variant?: 'mono' | 'reversed' | 'accent';
  size?: number; // mark height in px
  wordmark?: boolean;
  class?: string;
}
const { variant = 'accent', size = 30, wordmark = true, class: klass = '' } = Astro.props;

const ink = variant === 'reversed' ? '#FFFFFF' : '#0E1116';
const accent = variant === 'reversed' ? '#FFFFFF' : '#1466E0';
const barTop = variant === 'accent' || variant === 'reversed' ? accent : ink;
const word = variant === 'reversed' ? '#FFFFFF' : '#0E1116';
const wmSize = size * 0.9;
const gap = size * 0.35;
---

<span
  class={`inline-flex items-center ${klass}`}
  style={`gap:${gap}px`}
  aria-label="Indi"
>
  <svg
    width={size}
    height={size}
    viewBox="0 0 100 100"
    role="img"
    aria-hidden="true"
    style="display:block;flex:none;"
  >
    <rect x="26" y="54" width="13" height="20" rx="6.5" fill={ink} />
    <rect x="44" y="42" width="13" height="32" rx="6.5" fill={ink} />
    <rect x="62" y="28" width="13" height="46" rx="6.5" fill={barTop} />
    <circle cx="68.5" cy="18" r="5" fill={barTop} />
  </svg>
  {
    wordmark && (
      <span
        style={`font-family:var(--font-wordmark);font-weight:700;letter-spacing:-0.03em;font-size:${wmSize}px;color:${word};line-height:1;`}
      >
        Indi
      </span>
    )
  }
</span>
