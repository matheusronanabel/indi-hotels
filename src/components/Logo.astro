---
// Indi mark — three ascending bars, the tallest reading as a lowercase "i"
// with its dot. The mark stands alone: never place a wordmark beside it.
// Geometry mirrors public/indi-logo-assets/indi-mark*.svg (source of truth).
interface Props {
  variant?: 'default' | 'reversed' | 'mono-ink' | 'mono-white';
  size?: number; // mark height in px
  class?: string;
}
const { variant = 'default', size = 30, class: klass = '' } = Astro.props;

const barLow =
  variant === 'reversed' || variant === 'mono-white' ? '#FFFFFF' : '#0E1116';
const barTop =
  variant === 'mono-ink' ? '#0E1116'
  : variant === 'mono-white' ? '#FFFFFF'
  : variant === 'reversed' ? '#3B7BE0'
  : '#0E4FB0';
---

<svg
  width={size}
  height={size}
  viewBox="0 0 100 100"
  role="img"
  aria-label="Indi"
  class={klass}
  style="display:block;flex:none;"
>
  <rect x="14" y="60" width="16" height="30" rx="8" fill={barLow} />
  <rect x="41" y="42" width="16" height="48" rx="8" fill={barLow} />
  <rect x="68" y="28" width="16" height="62" rx="8" fill={barTop} />
  <circle cx="76" cy="13" r="8" fill={barTop} />
</svg>
