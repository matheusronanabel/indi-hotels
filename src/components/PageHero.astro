---
import { CTA } from '../data/site.js';
import Icon from './Icon.astro';
interface Props {
  eyebrow?: string;
  heading: string; // may contain <br>
  sub: string;
  secondary?: { label: string; href: string };
}
const { eyebrow, heading, sub, secondary } = Astro.props;
---
<section class="bg-[var(--color-paper)]">
  <div class="w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto px-6 sm:px-0 pt-28 pb-24 md:pt-36 md:pb-32">
    {eyebrow && <span class="eyebrow block mb-4" data-aos="fade-up">{eyebrow}</span>}
    <h1 class="display text-[clamp(34px,6vw,62px)] max-w-[18ch]" data-aos="fade-up">
      <Fragment set:html={heading} />
    </h1>
    <p class="serif-italic text-[clamp(19px,2.4vw,24px)] text-[var(--color-grey)] max-w-[44ch] mt-7" data-aos="fade-up" data-aos-delay="80">
      {sub}
    </p>
    <div class="flex flex-w-full max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto items-center gap-x-7 gap-y-4 mt-10" data-aos="fade-up" data-aos-delay="140">
      <a href={CTA.href} class="btn block w-fit btn-azure">{CTA.label}</a>
      {secondary && (
        <a href={secondary.href} class="tlink">
          {secondary.label}
          <Icon name="arrow_forward" size={17} />
        </a>
      )}
    </div>
  </div>
</section>
