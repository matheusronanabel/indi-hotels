---
interface Props {
  src?: string;
  alt?: string;
  label?: string;
  aspect?: 'landscape' | 'portrait' | 'wide';
  dark?: boolean;
  class?: string;
}
const {
  src,
  alt = 'Hotel property',
  label = 'Property photography',
  aspect = 'landscape',
  dark = false,
  class: cls,
} = Astro.props;

const aspectClass =
  aspect === 'portrait' ? 'aspect-[3/4]' : aspect === 'wide' ? 'aspect-[16/9]' : 'aspect-[4/3]';
---

{src && (
  <figure class:list={['overflow-hidden rounded-2xl', cls]}>
    <img
      src={src}
      alt={alt}
      class:list={['w-full h-full object-cover', aspectClass]}
      loading="lazy"
      decoding="async"
    />
  </figure>
)}

{!src && (
  <div
    class:list={[
      'relative overflow-hidden rounded-t-2xl flex flex-col justify-end',
      aspectClass,
      dark ? 'bg-[#1c1f21]' : 'bg-[var(--color-ash)]',
      cls,
    ]}
    role="img"
    aria-label={alt}
  >
    <!-- Soft gradient blobs using brand accent colours -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div
        class="absolute -top-1/4 -right-1/4 w-3/4 h-3/4 rounded-full"
        style="background: radial-gradient(circle, rgba(46,110,116,0.30) 0%, transparent 65%)"
      ></div>
      <div
        class="absolute -bottom-1/4 -left-1/4 w-1/2 h-1/2 rounded-full"
        style="background: radial-gradient(circle, rgba(192,139,71,0.16) 0%, transparent 70%)"
      ></div>
    </div>

    <!-- Hotel silhouette centred -->
    <div class="absolute inset-0 flex items-center justify-center" aria-hidden="true">
      <svg
        viewBox="0 96 960 960"
        class:list={['w-20 h-20', dark ? 'fill-white opacity-[0.07]' : 'fill-[#1A1B1D] opacity-[0.07]']}
        xmlns="http://www.w3.org/2000/svg"
      >
        <path d="M120 896V416l360-280 360 280v480H600V716H360v180H120Zm80-80h120V696h320v120h120V456L480 216 200 456v360Zm160-280h80v-80h-80v80Zm0 160h80v-80h-80v80Zm160-160h80v-80h-80v80Zm0 160h80v-80h-80v80ZM200 816V456v360Z" />
      </svg>
    </div>

    <!-- Bottom label -->
    <div class="relative px-6 py-5">
      <p
        class:list={[
          'font-mono text-[10px] tracking-[0.18em] uppercase',
          dark ? 'text-[#9a9c9e]' : 'text-[var(--color-grey)]',
        ]}
      >
        {label}
      </p>
    </div>
  </div>
)}
