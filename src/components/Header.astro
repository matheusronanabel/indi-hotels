---
import LogoAnimated from './LogoAnimated.astro';
import Icon from './Icon.astro';
import { NAV, CTA } from '../data/site.js';
const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? path === '/' : path === href || path.startsWith(href + '/');

// Groups with children get their own slide-in panel in the mobile overlay
// (see NavV4 in the albany-motel project — full-screen overlay, sliding
// panel-per-group, staggered link entrance). Panel 0 is always the top level.
const subGroups = NAV.filter((item) => item.children);
---

<header id="site-header" class="fixed top-0 left-0 right-0 z-50 border-b border-[var(--color-line)] bg-[var(--color-sand-1)]/85 backdrop-blur-md">
  <div class="w-full px-4 sm:px-0 max-w-full md:max-w-2xl lg:max-w-4xl xl:max-w-7xl mx-auto flex items-center justify-between h-[68px] gap-6">
    <a href="/" class="shrink-0 h-auto flex items-center" aria-label="Indi home">
      <LogoAnimated size={26} />
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-1" aria-label="Primary">
      {
        NAV.map((item) =>
          item.children ? (
            <div class="relative group">
              <a
                href={item.href}
                class:list={[
                  'flex items-center gap-1 px-3 py-2 rounded-md text-[15px] font-normal transition-colors',
                  isActive(item.href)
                    ? 'text-[var(--color-ink)]'
                    : 'text-[var(--color-grey)] hover:text-[var(--color-ink)]',
                ]}
                aria-haspopup="true"
              >
                {item.label}
                <Icon name="expand_more" size={18} class="transition-transform group-hover:rotate-180" />
              </a>
              <div class="absolute left-0 top-full pt-2 opacity-0 invisible translate-y-1 group-hover:opacity-100 group-hover:visible group-hover:translate-y-0 transition-all duration-200">
                <div class="card p-2 min-w-[244px] shadow-[0_18px_40px_-20px_rgba(0,0,0,0.3)]">
                  {item.children.map((c) => (
                    <a
                      href={c.href}
                      class:list={[
                        'block px-3 py-2.5 rounded-lg text-[15px] font-normal transition-colors',
                        isActive(c.href)
                          ? 'bg-[var(--color-ash)] text-[var(--color-ink)]'
                          : 'text-[var(--color-grey)] hover:bg-[var(--color-ash)] hover:text-[var(--color-ink)]',
                      ]}
                    >
                      {c.label}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          ) : (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 rounded-md text-[15px] font-normal transition-colors',
                isActive(item.href)
                  ? 'text-[var(--color-ink)]'
                  : 'text-[var(--color-grey)] hover:text-[var(--color-ink)]',
              ]}
            >
              {item.label}
            </a>
          )
        )
      }
    </nav>

    <div class="flex items-center gap-2">
      <!-- CTA only in desktop bar; on mobile it lives inside the overlay -->
        <a href={CTA.href} class="btn btn-azure hidden sm:inline-flex">{CTA.short}</a>

      <button
        id="menu-toggle"
        class="lg:hidden inline-flex items-center justify-center w-10 h-10 rounded-md border border-[var(--color-sand-line)] bg-[var(--color-sand)] text-[var(--color-ink)] transition-colors hover:border-[var(--color-ink)]"
        aria-label="Open menu"
        aria-expanded="false"
        aria-haspopup="dialog"
        aria-controls="mobile-nav-overlay"
      >
        <span class="nav-icon-open">
          <Icon name="menu" size={22} />
        </span>
        <span class="nav-icon-close hidden">
          <Icon name="close" size={22} />
        </span>
      </button>
    </div>
  </div>
</header>

<!-- Mobile nav overlay — full-screen takeover, sliding panel-per-group -->
<div
  id="mobile-nav-overlay"
  class="mnav lg:hidden fixed inset-0 z-[60] flex flex-col bg-[var(--color-sand-1)]"
  role="dialog"
  aria-modal="true"
  aria-label="Site navigation"
  aria-hidden="true"
>
  <div class="flex items-center justify-between px-4 shrink-0 h-[68px]">
    <a href="/" aria-label="Indi home" class="shrink-0 flex items-center">
      <LogoAnimated size={26} />
    </a>
    <button
      id="mobile-nav-close"
      aria-label="Close menu"
      class="inline-flex items-center justify-center w-10 h-10 rounded-md border border-[var(--color-sand-line)] text-[var(--color-ink)] transition-colors hover:border-[var(--color-ink)]"
    >
      <Icon name="close" size={22} />
    </button>
  </div>

  <div class="relative flex-1 min-h-0 overflow-hidden">
    <div id="mobile-nav-track" class="mnav-track flex h-full">
      <!-- Panel 0: top level -->
      <div class="mnav-panel shrink-0 w-full h-full overflow-y-auto px-6 sm:px-10 flex flex-col justify-center" data-panel-index="0">
        <nav aria-label="Mobile primary" class="flex flex-col">
          {NAV.map((item, i) => (
            item.children ? (
              <button
                type="button"
                data-open-panel={subGroups.indexOf(item) + 1}
                class="mnav-item display flex items-center justify-between gap-3 py-3 text-left text-[var(--color-ink)] border-b border-[var(--color-sand-line)]"
                style={`transition-delay:${60 + i * 50}ms`}
              >
                <span>{item.label}</span>
                <Icon name="expand_more" size={22} class="-rotate-90 opacity-50 shrink-0" />
              </button>
            ) : (
              <a
                href={item.href}
                class="mnav-item display py-3 text-[var(--color-ink)] border-b border-[var(--color-sand-line)]"
                style={`transition-delay:${60 + i * 50}ms`}
              >
                {item.label}
              </a>
            )
          ))}
        </nav>
        <a
          href={CTA.href}
          class="mnav-item btn btn-azure text-center justify-center mt-8"
          style={`transition-delay:${60 + NAV.length * 50}ms`}
        >
          {CTA.label}
        </a>
      </div>

      <!-- Panel per group with children -->
      {subGroups.map((item) => (
        <div class="mnav-panel shrink-0 w-full h-full overflow-y-auto px-6 sm:px-10 flex flex-col justify-center" data-panel-index={subGroups.indexOf(item) + 1}>
          <button
            type="button"
            data-back
            class="flex items-center gap-2 mb-6 text-[13px] font-semibold uppercase tracking-wide text-[var(--color-grey)] transition-colors hover:text-[var(--color-ink)]"
          >
            <Icon name="arrow_forward" size={16} class="rotate-180" />
            Back
          </button>
          <nav aria-label={item.label} class="flex flex-col">
            {item.children!.map((c) => (
              <a href={c.href} class="display py-2.5 text-[clamp(20px,5vw,28px)] text-[var(--color-ink)]">
                {c.label}
              </a>
            ))}
          </nav>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .mnav {
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.4s ease, visibility 0s linear 0.4s;
  }
  .mnav.is-open {
    visibility: visible;
    opacity: 1;
    transition: opacity 0.4s ease;
  }
  .mnav-track {
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .mnav-item {
    transform: translateY(16px);
    opacity: 0;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    font-size: clamp(26px, 8vw, 38px);
  }
  .mnav.is-open .mnav-item {
    transform: translateY(0);
    opacity: 1;
  }
  /* CTA keeps the standard .btn size — the clamp() above is for nav links only */
  .mnav-item.btn {
    font-size: 14.5px;
  }
</style>

<script>
  const overlay = document.getElementById('mobile-nav-overlay');
  const track = document.getElementById('mobile-nav-track') as HTMLElement | null;
  const toggle = document.getElementById('menu-toggle');
  const closeBtn = document.getElementById('mobile-nav-close');
  const panels = Array.from(overlay?.querySelectorAll<HTMLElement>('[data-panel-index]') ?? []);
  const iconOpen = toggle?.querySelector('.nav-icon-open');
  const iconClose = toggle?.querySelector('.nav-icon-close');

  let isOpen = false;
  let activeIndex = 0;
  let lastTrigger: HTMLElement | null = null;
  let resetTimer: ReturnType<typeof setTimeout>;

  function applyTrack() {
    if (track) track.style.transform = `translateX(-${activeIndex * 100}%)`;
  }

  function setOpenState(open: boolean) {
    isOpen = open;
    overlay?.classList.toggle('is-open', open);
    overlay?.setAttribute('aria-hidden', open ? 'false' : 'true');
    document.body.style.overflow = open ? 'hidden' : '';
    toggle?.setAttribute('aria-expanded', String(open));
    toggle?.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
    iconOpen?.classList.toggle('hidden', open);
    iconClose?.classList.toggle('hidden', !open);
  }

  function goToPanel(i: number) {
    activeIndex = i;
    applyTrack();
    const target = i === 0 ? lastTrigger : panels[i]?.querySelector<HTMLElement>('[data-back]');
    setTimeout(() => target?.focus(), 500);
  }

  function openMenu() {
    clearTimeout(resetTimer);
    activeIndex = 0;
    applyTrack();
    setOpenState(true);
  }

  function closeMenu() {
    setOpenState(false);
    resetTimer = setTimeout(() => {
      activeIndex = 0;
      applyTrack();
    }, 500);
  }

  toggle?.addEventListener('click', () => (isOpen ? closeMenu() : openMenu()));
  closeBtn?.addEventListener('click', closeMenu);

  overlay?.querySelectorAll<HTMLElement>('[data-open-panel]').forEach((btn) => {
    btn.addEventListener('click', () => {
      lastTrigger = btn;
      goToPanel(Number(btn.dataset.openPanel));
    });
  });

  overlay?.querySelectorAll<HTMLElement>('[data-back]').forEach((btn) => {
    btn.addEventListener('click', () => goToPanel(0));
  });

  overlay?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', closeMenu);
  });

  window.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape' || !isOpen) return;
    if (activeIndex !== 0) goToPanel(0);
    else closeMenu();
  });
</script>
