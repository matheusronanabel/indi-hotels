---
// First-visit splash — the full loop from public/indi-logo-animated/indi-mark-animated.svg,
// "where motion is the point" per indi-animated-logo-handoff.md. Shows once per
// session (sessionStorage), skipped entirely for prefers-reduced-motion, and the
// inline script below runs synchronously (is:inline, not a module) so a repeat
// page load in the same session removes it before first paint — no flash.
---

<div
  id="indi-splash"
  role="status"
  aria-label="Loading"
  class="fixed inset-0 z-[200] flex items-center justify-center bg-[var(--color-paper)]"
>
  <svg width="72" height="72" viewBox="0 0 100 100" role="img" aria-label="Indi">
    <style>
      #indi-splash .b1,#indi-splash .b2,#indi-splash .b3{transform-box:fill-box;transform-origin:center bottom;}
      #indi-splash .dot{transform-box:fill-box;transform-origin:center;}
      #indi-splash .b1{animation:indi-loop-b1 6s ease-in-out infinite;}
      #indi-splash .b2{animation:indi-loop-b2 6s ease-in-out infinite;}
      #indi-splash .b3{animation:indi-loop-b3 6s ease-in-out infinite;}
      #indi-splash .dot{animation:indi-loop-dot 6s ease-in-out infinite;}
      @keyframes indi-loop-b1{
        0%{opacity:0;transform:translateY(7px);} 8%{opacity:1;transform:translateY(0);}
        58%{opacity:1;transform:translateY(0);} 64%{opacity:0;transform:translateY(7px);}
        100%{opacity:0;transform:translateY(7px);}
      }
      @keyframes indi-loop-b2{
        0%,8%{opacity:0;transform:translateY(7px);} 16%{opacity:1;transform:translateY(0);}
        64%{opacity:1;transform:translateY(0);} 70%{opacity:0;transform:translateY(7px);}
        100%{opacity:0;transform:translateY(7px);}
      }
      @keyframes indi-loop-b3{
        0%,16%{opacity:0;transform:translateY(7px);fill:#0E1116;}
        24%{opacity:1;transform:translateY(0);fill:#0E1116;}
        30%{fill:#0E4FB0;}
        70%{opacity:1;transform:translateY(0);fill:#0E4FB0;}
        78%{opacity:0;transform:translateY(7px);fill:#0E4FB0;}
        100%{opacity:0;transform:translateY(7px);}
      }
      @keyframes indi-loop-dot{
        0%,26%{opacity:0;transform:scale(.2);} 30%{opacity:1;transform:scale(1.15);} 33%{transform:scale(1);}
        70%{opacity:1;transform:scale(1);} 76%{opacity:0;transform:scale(.2);}
        100%{opacity:0;transform:scale(.2);}
      }
    </style>
    <rect class="b1" x="14" y="60" width="16" height="30" rx="8" fill="#0E1116" />
    <rect class="b2" x="41" y="42" width="16" height="48" rx="8" fill="#0E1116" />
    <rect class="b3" x="68" y="28" width="16" height="62" rx="8" fill="#0E1116" />
    <circle class="dot" cx="76" cy="13" r="8" fill="#0E4FB0" />
  </svg>
</div>

<noscript>
  <style>#indi-splash{display:none}</style>
</noscript>

<style>
  #indi-splash {
    transition: opacity 0.45s ease;
  }
  #indi-splash.is-hiding {
    opacity: 0;
    pointer-events: none;
  }
</style>

<script is:inline>
  (function () {
    var splash = document.getElementById('indi-splash');
    if (!splash) return;

    var reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    var seen = sessionStorage.getItem('indi-splash-seen');

    if (seen || reduced) {
      splash.remove();
      return;
    }
    sessionStorage.setItem('indi-splash-seen', '1');

    var MIN_MS = 2200;
    var minTimeReached = false;
    var pageLoaded = document.readyState === 'complete';

    document.documentElement.style.overflow = 'hidden';

    function maybeHide() {
      if (!minTimeReached || !pageLoaded) return;
      document.documentElement.style.overflow = '';
      splash.classList.add('is-hiding');
      setTimeout(function () {
        splash.remove();
      }, 500);
    }

    if (!pageLoaded) {
      window.addEventListener('load', function () {
        pageLoaded = true;
        maybeHide();
      });
    }

    setTimeout(function () {
      minTimeReached = true;
      maybeHide();
    }, MIN_MS);
  })();
</script>
